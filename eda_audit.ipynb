# =========================================
# 1. IMPORTS
# =========================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

sns.set_style("whitegrid")

# =========================================
# 2. LOAD DATA
# =========================================
customers = pd.read_csv("../data/customers.csv")
orders = pd.read_csv("../data/orders.csv")
support = pd.read_csv("../data/support_tickets.csv")
web = pd.read_csv("../data/web_events.csv")
churn = pd.read_csv("../data/churn_labels.csv")
campaign = pd.read_csv("../data/campaigns.csv")

# =========================================
# 3. BASIC INSPECTION
# =========================================
datasets = {
    "customers": customers,
    "orders": orders,
    "support": support,
    "web": web,
    "churn": churn,
    "campaign": campaign
}

for name, df in datasets.items():
    print(f"\n{name.upper()}")
    print("Shape:", df.shape)
    print(df.head())

# =========================================
# 4. DATA QUALITY CHECKS
# =========================================

# Missing values
for name, df in datasets.items():
    print(f"\nMissing Values in {name}:")
    print(df.isnull().sum().sort_values(ascending=False).head())

# Duplicate checks
for name, df in datasets.items():
    print(f"{name} duplicates:", df.duplicated().sum())

# =========================================
# 5. DATE CONVERSION
# =========================================
orders['order_date'] = pd.to_datetime(orders['order_date'])
support['ticket_date'] = pd.to_datetime(support['ticket_date'])
web['event_time'] = pd.to_datetime(web['event_time'])
campaign['campaign_date'] = pd.to_datetime(campaign['campaign_date'])

# =========================================
# 6. FEATURE ENGINEERING (Customer Level)
# =========================================

# Orders aggregation
order_agg = orders.groupby('customer_id').agg({
    'order_id': 'count',
    'order_value': ['sum', 'mean'],
    'order_date': ['max', 'min']
})

order_agg.columns = ['total_orders', 'total_spent', 'avg_order_value', 'last_order_date', 'first_order_date']
order_agg.reset_index(inplace=True)

# Recency
snapshot_date = orders['order_date'].max()
order_agg['recency_days'] = (snapshot_date - order_agg['last_order_date']).dt.days

# Support tickets
support_agg = support.groupby('customer_id').agg({
    'ticket_id': 'count'
}).reset_index().rename(columns={'ticket_id': 'ticket_count'})

# Web activity
web_agg = web.groupby('customer_id').agg({
    'event_type': 'count'
}).reset_index().rename(columns={'event_type': 'web_events'})

# Campaign touches
campaign_agg = campaign.groupby('customer_id').agg({
    'campaign_id': 'count'
}).reset_index().rename(columns={'campaign_id': 'campaign_count'})

# =========================================
# 7. MERGE ALL DATA
# =========================================
df = customers.merge(order_agg, on='customer_id', how='left')
df = df.merge(support_agg, on='customer_id', how='left')
df = df.merge(web_agg, on='customer_id', how='left')
df = df.merge(campaign_agg, on='customer_id', how='left')
df = df.merge(churn, on='customer_id', how='left')

df.fillna(0, inplace=True)

print("Final Dataset Shape:", df.shape)

# =========================================
# 8. CHURN DISTRIBUTION
# =========================================
plt.figure()
sns.countplot(x='churn', data=df)
plt.title("Churn Distribution")
plt.show()

# =========================================
# 9. EDA CHARTS
# =========================================

# 1. Total Orders vs Churn
plt.figure()
sns.boxplot(x='churn', y='total_orders', data=df)
plt.title("Orders vs Churn")
plt.show()

# 2. Recency vs Churn
plt.figure()
sns.boxplot(x='churn', y='recency_days', data=df)
plt.title("Recency vs Churn")
plt.show()

# 3. Spending vs Churn
plt.figure()
sns.boxplot(x='churn', y='total_spent', data=df)
plt.title("Total Spend vs Churn")
plt.show()

# 4. Support Tickets vs Churn
plt.figure()
sns.boxplot(x='churn', y='ticket_count', data=df)
plt.title("Support Tickets vs Churn")
plt.show()

# 5. Web Activity vs Churn
plt.figure()
sns.boxplot(x='churn', y='web_events', data=df)
plt.title("Web Activity vs Churn")
plt.show()

# 6. Campaign Exposure vs Churn
plt.figure()
sns.boxplot(x='churn', y='campaign_count', data=df)
plt.title("Campaign Exposure vs Churn")
plt.show()

# =========================================
# 10. CORRELATION HEATMAP
# =========================================
plt.figure(figsize=(10,6))
sns.heatmap(df.corr(numeric_only=True), annot=True, cmap='coolwarm')
plt.title("Feature Correlations")
plt.show()
