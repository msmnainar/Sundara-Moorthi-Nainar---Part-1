  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def convert_date_columns(df, df_name=\"\"):\n",
    "    for col in df.columns:\n",
    "        if \"date\" in col.lower() or \"time\" in col.lower():\n",
    "            try:\n",
    "                df[col] = pd.to_datetime(df[col])\n",
    "                print(f\"✅ Converted {df_name}.{col}\")\n",
    "            except:\n",
    "                print(f\"⚠️ Could not convert {df_name}.{col}\")\n",
    "    return df\n",
    "\n",
    "orders = convert_date_columns(orders, \"orders\")\n",
    "support = convert_date_columns(support, \"support\")\n",
    "web = convert_date_columns(web, \"web\")\n",
    "campaign = convert_date_columns(campaign, \"campaign\")"
   ]
  },
