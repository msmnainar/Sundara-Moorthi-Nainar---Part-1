 SECTION 3: Convert Dates
#function to safely convert date/time columns
def convert_date_columns(df, df_name=""):
    for col in df.columns:
        if "date" in col.lower() or "time" in col.lower():
            try:
                df[col] = pd.to_datetime(df[col])
                print(f"✅ Converted {df_name}.{col}")
            except:
                print(f"⚠️ Could not convert {df_name}.{col}")
    return df


#apply to all datasets
