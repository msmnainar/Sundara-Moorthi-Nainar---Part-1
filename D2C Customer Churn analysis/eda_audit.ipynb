SECTION 5: Merge Everything
import pandas as pd
import numpy as np

# -----------------------------
# LOAD DATA
# -----------------------------
customers = pd.read_csv('customers.csv')
orders = pd.read_csv('orders.csv')
tickets = pd.read_csv('support_tickets.csv')
web = pd.read_csv('web_events_snapshot.csv')
churn = pd.read_csv('churn_labels.csv')
interventions = pd.read_csv('intervention_history.csv')

# -----------------------------
# DATE FORMATTING
# -----------------------------
orders['order_date'] = pd.to_datetime(orders['order_date'])
tickets['ticket_date'] = pd.to_datetime(tickets['ticket_date'])
churn['snapshot_date'] = pd.to_datetime(churn['snapshot_date'])
web['snapshot_date'] = pd.to_datetime(web['snapshot_date'])
interventions['snapshot_date'] = pd.to_datetime(interventions['snapshot_date'])

# -----------------------------
# FILTER DATA (NO LEAKAGE)
# -----------------------------
orders = orders.merge(churn[['customer_id','snapshot_date']], on='customer_id')
orders = orders[orders['order_date'] <= orders['snapshot_date']]

tickets = tickets.merge(churn[['customer_id','snapshot_date']], on='customer_id')
tickets = tickets[tickets['ticket_date'] <= tickets['snapshot_date']]

# -----------------------------
# ORDER FEATURES
# -----------------------------
order_agg = orders.groupby('customer_id').agg({
    'order_id': 'count',
    'gross_amount': ['sum', 'mean'],
    'returned': 'sum',
    'rating': 'mean'
}).reset_index()

order_agg.columns = [
    'customer_id',
    'total_orders',
    'total_spend',
    'avg_order_value',
    'total_returns',
    'avg_rating'
]

# Recency
last_order = orders.groupby('customer_id')['order_date'].max().reset_index()
last_order.columns = ['customer_id','last_order_date']

last_order = last_order.merge(churn[['customer_id','snapshot_date']])
last_order['recency_days'] = (
    last_order['snapshot_date'] - last_order['last_order_date']
).dt.days

order_agg = order_agg.merge(last_order[['customer_id','recency_days']], on='customer_id', how='left')

# -----------------------------
# ✅ SUPPORT FEATURES
# -----------------------------
support_agg = tickets.groupby('customer_id').agg({
    'ticket_id': 'count',
    'resolution_hours': 'mean',
    'sentiment_score': 'mean',
    'reopened': 'sum'
}).reset_index()

support_agg.columns = [
    'customer_id',
    'ticket_count',
    'avg_resolution_time',
    'avg_sentiment',
    'reopened_tickets'
]

# -----------------------------
# WEB FEATURES
# -----------------------------
web_agg = web.copy()

web_agg['engagement_score'] = (
    web_agg['sessions_30d'] +
    web_agg['product_views_30d'] +
    web_agg['cart_adds_30d']
)

web_agg['conversion_rate'] = (
    web_agg['cart_adds_30d'] / web_agg['sessions_30d']
).replace([np.inf, -np.inf], 0)

# -----------------------------
# CAMPAIGN FEATURES
# -----------------------------
campaign_agg = interventions.copy()

campaign_agg['received_campaign'] = campaign_agg['last_campaign_received'].apply(
    lambda x: 0 if x == 'none' else 1
)

campaign_agg['high_value_campaign'] = campaign_agg['last_campaign_cost'].apply(
    lambda x: 1 if x > 20 else 0
)

# -----------------------------
# ✅ SECTION 5: MERGE EVERYTHING
# -----------------------------
df_final = churn.copy()

df_final = df_final.merge(customers, on='customer_id', how='left')
df_final = df_final.merge(order_agg, on='customer_id', how='left')
df_final = df_final.merge(support_agg, on='customer_id', how='left')
df_final = df_final.merge(web_agg, on=['customer_id','snapshot_date'], how='left')
df_final = df_final.merge(campaign_agg, on=['customer_id','snapshot_date'], how='left')

# -----------------------------
# HANDLE MISSING VALUES
# -----------------------------
df_final.fillna(0, inplace=True)

# -----------------------------
# OUTPUT
# -----------------------------
print("✅ No errors — dataset ready")
print("Shape:", df_final.shape)
df_final.head()
